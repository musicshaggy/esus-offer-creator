{
  "name": "esus-quote-generator",
  "version": "1.3.2",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir", 
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.4.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.1.0",
    "electron-updater": "^6.4.0"
  },
  "build": {
    "appId": "pl.esus.app",
    "productName": "ESUS IT Offer Generator",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/favicon.ico"
    },
	"publish": [
      {
        "provider": "github",
        "owner": "musicshaggy",
        "repo": "esus-offer-creator",
        "releaseType": "release"
      }
    ]
  }
}
